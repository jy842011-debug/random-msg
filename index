<!DOCTYPE html>

<html lang="ko">

<head>

<meta charset="UTF-8">

<title>랜덤 문구</title>

<style>

body { 
  background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://raw.githubusercontent.com/jy842011-debug/random-msg/main/3643882.jpg');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  background-attachment: fixed;
}

</style>

</head>

<body>

<h1 id="msg">터치하세요!</h1>

<script>

const msgs = ["오늘도 화이팅 💕", "웃으며 하루 보내요 😊", "너는 최고야! ✨", "좋은 일 가득! 🌟", "너 정말 잘해 💖", "오늘도 빛나 ✨", "괜찮아 다 지나가 😌", "너의 가능성 무한해 🌈", "천천히 가도 돼 🐢", "이미 충분해 🌟", "작은 승리 축하! 🎉", "내일도 화이팅 💪", "너만의 매력 최고 💎"];

const msgEl = document.getElementById("msg");

msgEl.innerText = msgs[Math.floor(Math.random() * msgs.length)];

</script>

</body>

</html>
